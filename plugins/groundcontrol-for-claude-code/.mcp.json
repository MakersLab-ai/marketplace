{
  "mcpServers": {
    "groundcontrol": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/dist/index.js"],
      "env": {
        "GC_API_KEY": "${GC_API_KEY}",
        "GC_API_URL": "${GC_API_URL:-https://groundcontrol.makerslab.ai/api/v1}",
        "GC_INITIATIVE_ID": "${GC_INITIATIVE_ID}"
      }
    }
  }
}
